+class Parser:
+    """Recursive descent parser for the configuration format."""
 
+    def __init__(self, tokens: list[Token]) -> None:
+        self.tokens = tokens
+        self.pos = 0
+
+    def _current(self) -> Token:
+        return self.tokens[self.pos]
+
+    def _expect(self, token_type: TokenType) -> Token:
+        token = self._current()
+        if token.type != token_type:
+            raise ParseError(
+                f"Expected {token_type.name} but got {token.type.name} "
+                f"at line {token.line}"
+            )
+        self.pos += 1
+        return token
+
+    def _match(self, token_type: TokenType) -> Token | None:
+        if self._current().type == token_type:
+            token = self._current()
+            self.pos += 1
+            return token
+        return None
+
+    def parse(self) -> dict[str, Any]:
+        """Parse the token stream into a configuration dictionary."""
+        result: dict[str, Any] = {}
+        while self._current().type != TokenType.EOF:
+            name_token = self._expect(TokenType.IDENTIFIER)
+            self._expect(TokenType.LBRACE)
+            result[name_token.value] = self._parse_block()
+            self._expect(TokenType.RBRACE)
+        return result
+
+    def _parse_block(self) -> dict[str, Any]:
+        """Parse the contents of a { ... } block."""
+        result: dict[str, Any] = {}
+        while self._current().type not in (TokenType.RBRACE, TokenType.EOF):
+            key_token = self._expect(TokenType.IDENTIFIER)
+            if self._current().type == TokenType.LBRACE:
+                # Nested block
+                self._expect(TokenType.LBRACE)
+                result[key_token.value] = self._parse_block()
+                self._expect(TokenType.RBRACE)
+            elif self._current().type == TokenType.EQUALS:
+                self._expect(TokenType.EQUALS)
+                result[key_token.value] = self._parse_value()
+            else:
+                raise ParseError(
+                    f"Expected '=' or '{{' after key {key_token.value!r} "
+                    f"at line {key_token.line}"
+                )
+        return result
+
+    def _parse_value(self) -> Any:
+        """Parse a single value (string, number, boolean, or array)."""
+        token = self._current()
+        if token.type == TokenType.STRING:
+            self.pos += 1
+            return token.value
+        if token.type == TokenType.INTEGER:
+            self.pos += 1
+            return token.value
+        if token.type == TokenType.FLOAT:
+            self.pos += 1
+            return token.value
+        if token.type == TokenType.BOOLEAN:
+            self.pos += 1
+            return token.value
+        if token.type == TokenType.LBRACKET:
+            return self._parse_array()
+        raise ParseError(
+            f"Unexpected token {token.type.name} at line {token.line}"
+        )
+
+    def _parse_array(self) -> list[Any]:
+        """Parse an array value: [ item, item, ... ]."""
+        self._expect(TokenType.LBRACKET)
+        items: list[Any] = []
+        if self._current().type == TokenType.RBRACKET:
+            self._expect(TokenType.RBRACKET)
+            return items
+        items.append(self._parse_value())
+        while self._match(TokenType.COMMA):
+            items.append(self._parse_value())
+        self._expect(TokenType.RBRACKET)
+        return items
+
+
+def parse_config(text: str) -> dict[str, Any]:
+    """Parse a custom config format into a dictionary.
+
+    Uses a recursive descent parser with proper error reporting.
+    """
+    lexer = Lexer(text)
+    tokens = lexer.tokenize()
+    parser = Parser(tokens)
+    return parser.parse()
