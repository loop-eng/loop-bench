+package config
+
+// Config holds the unified application configuration.
+// All configuration sources are merged into this single struct.
+type Config struct {
+	Host     string
+	Port     int
+	Debug    bool
+	LogLevel string
+	DBHost   string
+	DBPort   int
+	DBName   string
+	Workers  int
+}
+
+// Defaults returns a Config populated with sensible default values.
+func Defaults() Config {
+	return Config{
+		Host:     "localhost",
+		Port:     8080,
+		Debug:    false,
+		LogLevel: "info",
+		DBHost:   "localhost",
+		DBPort:   5432,
+		DBName:   "app",
+		Workers:  4,
+	}
+}
+
+// LoadConfig loads configuration with clear precedence ordering:
+//
+//	defaults < config file < environment variables < CLI flags
+//
+// Each layer only overrides fields it explicitly sets (non-zero values).
+// If filePath is empty or the file does not exist, the file layer is skipped.
+// If args is nil or empty, the CLI flag layer is skipped.
+func LoadConfig(filePath string, args []string) Config {
+	cfg := Defaults()
+
+	// Layer 1: Config file (lowest priority after defaults)
+	if filePath != "" {
+		if fileCfg, err := LoadFromFile(filePath); err == nil && fileCfg.Loaded {
+			mergeFileConfig(&cfg, fileCfg)
+		}
+	}
+
+	// Layer 2: Environment variables
+	envCfg := LoadFromEnv()
+	mergeEnvConfig(&cfg, envCfg)
+
+	// Layer 3: CLI flags (highest priority)
+	if len(args) > 0 {
+		flagCfg := ParseFlags(args)
+		if flagCfg.Parsed {
+			mergeFlagConfig(&cfg, flagCfg)
+		}
+	}
+
+	return cfg
+}
+
+func mergeFileConfig(dst *Config, src FileConfig) {
+	if src.Host != "" {
+		dst.Host = src.Host
+	}
+	if src.Port != 0 {
+		dst.Port = src.Port
+	}
+	if src.Debug {
+		dst.Debug = src.Debug
+	}
+	if src.LogLevel != "" {
+		dst.LogLevel = src.LogLevel
+	}
+	if src.DBHost != "" {
+		dst.DBHost = src.DBHost
+	}
+	if src.DBPort != 0 {
+		dst.DBPort = src.DBPort
+	}
+	if src.DBName != "" {
+		dst.DBName = src.DBName
+	}
+	if src.Workers != 0 {
+		dst.Workers = src.Workers
+	}
+}
+
+func mergeEnvConfig(dst *Config, src EnvConfig) {
+	if src.Host != "" {
+		dst.Host = src.Host
+	}
+	if src.Port != 0 {
+		dst.Port = src.Port
+	}
+	if src.Debug {
+		dst.Debug = src.Debug
+	}
+	if src.LogLevel != "" {
+		dst.LogLevel = src.LogLevel
+	}
+	if src.DBHost != "" {
+		dst.DBHost = src.DBHost
+	}
+	if src.DBPort != 0 {
+		dst.DBPort = src.DBPort
+	}
+	if src.DBName != "" {
+		dst.DBName = src.DBName
+	}
+	if src.Workers != 0 {
+		dst.Workers = src.Workers
+	}
+}
+
+func mergeFlagConfig(dst *Config, src FlagConfig) {
+	if src.Host != "" {
+		dst.Host = src.Host
+	}
+	if src.Port != 0 {
+		dst.Port = src.Port
+	}
+	if src.Debug {
+		dst.Debug = src.Debug
+	}
+	if src.LogLevel != "" {
+		dst.LogLevel = src.LogLevel
+	}
+	if src.DBHost != "" {
+		dst.DBHost = src.DBHost
+	}
+	if src.DBPort != 0 {
+		dst.DBPort = src.DBPort
+	}
+	if src.DBName != "" {
+		dst.DBName = src.DBName
+	}
+	if src.Workers != 0 {
+		dst.Workers = src.Workers
+	}
+}
