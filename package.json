{
  "name": "@loop-eng/bench",
  "version": "0.1.0",
  "description": "SWE-bench for loop designs — standardized benchmarks that measure loop architecture quality beyond pass/fail",
  "type": "module",
  "bin": {
    "bench": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "spec",
    "tasks",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint harness/src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "loop-engineering",
    "benchmark",
    "agent",
    "loop",
    "harness",
    "scaffold",
    "swe-bench",
    "ltf",
    "evaluation",
    "claude",
    "codex",
    "coding-agent"
  ],
  "author": "Raj Firke <rajfirke23@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/loop-eng/loop-bench.git"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "commander": "^13.1.0",
    "dockerode": "^4.0.7",
    "picocolors": "^1.1.1",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.38",
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "eslint": "^9.28.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
